# syntax=docker/dockerfile:1.7
#
# adventurer-poc — CUDA build, NVIDIA-blessed base.
#
# Why a separate Dockerfile from the CPU/Vulkan one:
# - NVIDIA's CUDA images bake in nvcc + CUDA libs at standard Ubuntu paths
# - The runtime image's ld.so config + Vulkan/CUDA loader paths are pre-wired
#   to work with NVIDIA Container Toolkit / CDI device passthrough — no
#   LD_LIBRARY_PATH gymnastics needed
# - Image is bigger (~3 GB) but GPU "just works" with --device nvidia.com/gpu=all
#
# Build:
#   docker build -f Dockerfile.cuda -t adventurer:cuda .
#
# Run (LLM PoC):
#   docker run --rm --device nvidia.com/gpu=all \
#       -v /var/home/me/repos/adventurer/models:/models:ro \
#       adventurer:cuda adventurer-poc \
#       --model /models/gemma-4-E4B-it-Q4_K_M.gguf \
#       --gpu-layers 99
#
# Run (STT PoC — needs ffmpeg in the image):
#   docker run --rm --device nvidia.com/gpu=all \
#       -v /var/home/me/repos/adventurer/models:/models:ro \
#       -v /var/home/me/repos/adventurer/samples:/work/samples:ro \
#       adventurer:cuda adventurer-stt-poc \
#       --model /models/ggml-medium.bin \
#       --audio /work/samples/audio/clip.mp3

ARG CUDA_VERSION=12.6.0
ARG UBUNTU_VERSION=24.04

# ────────────── builder stage ──────────────
FROM nvidia/cuda:${CUDA_VERSION}-devel-ubuntu${UBUNTU_VERSION} AS builder

# Rust isn't in the CUDA image; install via rustup
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH \
    DEBIAN_FRONTEND=noninteractive

# Install build deps + rustup
# libnccl-dev: llama.cpp 0.1.x auto-enables NCCL multi-GPU collectives when nvcc
# is present; the dev image doesn't ship libnccl. Add it to satisfy the linker.
# (Symbols are dead code for single-GPU runs, but must resolve.)
RUN apt-get update && apt-get install -y --no-install-recommends \
        cmake \
        build-essential \
        pkg-config \
        clang \
        libclang-dev \
        libomp-dev \
        libnccl-dev=2.22.3-1+cuda12.6 \
        git \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
       | sh -s -- -y --default-toolchain 1.95.0 --profile minimal \
    && rustc --version

# Make nvcc visible (CUDA images sometimes don't put it on PATH by default)
ENV PATH=/usr/local/cuda/bin:$PATH \
    LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH

WORKDIR /work
COPY Cargo.toml ./
COPY crates ./crates
COPY prompts ./prompts
COPY samples ./samples

# Default GPU feature: cuda. (The inference crate's `cuda` feature already pulls
# `cuda-no-vmm` to avoid "CUDA Virtual Memory Management is not available"
# errors under some CDI passthrough configs.)
ARG CARGO_FEATURES=cuda

# `-lnccl` — llama-cpp-sys-2 0.1.145 unconditionally emits NCCL symbols when
# CUDA is on, but its build.rs doesn't emit `cargo:rustc-link-lib=nccl`.
#
# Note: we deliberately do NOT link both llama-cpp-sys-2 AND whisper-rs-sys into
# the same binary — they each vendor their own ggml and the duplicate symbols
# silently produce a runtime-crashing binary. The architecture instead splits
# inference across worker processes (see crates/inference-{llm,stt}).
ENV RUSTFLAGS="-C link-arg=-lnccl"

# Workspace build: explicit -p per crate. Cargo doesn't allow --features with
# --workspace; the bench crates carry GPU features and the server doesn't.
# (Server links neither llama nor whisper — see crates/server/Cargo.toml.)
# Cargo cache mount shares C++ artifacts across the bench builds.
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/work/target,sharing=locked \
    cargo build --release -p adventurer-server && \
    cargo build --release -p adventurer-llm-bench  --features "$CARGO_FEATURES" && \
    cargo build --release -p adventurer-stt-bench  --features "$CARGO_FEATURES" && \
    cp target/release/adventurer            /adventurer && \
    cp target/release/adventurer-llm-bench  /adventurer-llm-bench && \
    cp target/release/adventurer-stt-bench  /adventurer-stt-bench

# ────────────── runtime stage ──────────────
FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu${UBUNTU_VERSION} AS runtime

# libnccl2 is already in the cuda-runtime base image (held package).
# ffmpeg: lazy audio decode for adventurer-stt-poc — webm/mp3/wav → 16 kHz f32 PCM.
# (The eventual production binary will use `symphonia` for pure-Rust decoding.)
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgomp1 \
        ffmpeg \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /adventurer            /usr/local/bin/adventurer
COPY --from=builder /adventurer-llm-bench  /usr/local/bin/adventurer-llm-bench
COPY --from=builder /adventurer-stt-bench  /usr/local/bin/adventurer-stt-bench
COPY prompts /work/prompts
COPY samples /work/samples
WORKDIR /work

# Default CMD launches the actual server. Override with one of:
#   docker run image adventurer-llm-bench --model …
#   docker run image adventurer-stt-bench --audio …
CMD ["adventurer"]
