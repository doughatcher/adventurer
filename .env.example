# adventurer — local config (sourced by scripts/launch.sh).
# Copy this to `.env` (gitignored) and fill in real values.
# Project .env beats ~/.env because the launcher sources project last.

# ── GitHub session sync (POST /api/session/save) ──
# PAT needs `contents: write` scope on the target repo.
ADVENTURER_GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
ADVENTURER_GITHUB_REPO=doughatcher/adventure-log
ADVENTURER_GITHUB_BRANCH=main

# ── Public URL (for the QR code) ──
# iPad / iOS Safari refuses getUserMedia() over plain HTTP, so when sharing
# the QR with phones you'll want the HTTPS URL of your Cloudflare Tunnel /
# reverse-proxy hostname here. If unset we fall back to the LAN IP.
ADVENTURER_PUBLIC_URL=https://adventurer.superterran.net

# ── Optional ──
# ADVENTURER_PORT=3210                              # server listens here
# ADVENTURER_DPI_SCALE=2.0                          # Chrome --force-device-scale-factor
# ADVENTURER_HEADLESS=1                             # don't launch Chrome
# ADVENTURER_DEV=1                                  # mount assets/ from host (live reload)
# ADVENTURER_IMAGE=adventurer:cuda                  # override docker image tag
# ADVENTURER_SESSION=$HOME/.local/share/adventurer/session   # session archive dir
